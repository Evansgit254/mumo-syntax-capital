[Unit]
Description=TradingExpert Admin Dashboard Server
After=network.target

[Service]
Type=simple
WorkingDirectory=/home/evans/mumo-syntax-capital
Environment="PYTHONPATH=/home/evans/mumo-syntax-capital"
ExecStart=/home/evans/mumo-syntax-capital/venv/bin/python /home/evans/mumo-syntax-capital/admin_server.py
Restart=always
RestartSec=30

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=mumo-admin

[Install]
WantedBy=multi-user.target
