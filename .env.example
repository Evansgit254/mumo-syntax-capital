# Pure Quant Trading System - Environment Configuration
# Copy this to .env and fill in the values

# Existing Settings
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id
GEMINI_API_KEY=your_gemini_api_key

# --- SECURITY UPGRADE (V22.1) ---

# JWT Secret for signed sessions (Required for persistence)
# Generate one with: openssl rand -hex 32
JWT_SECRET=your_32_byte_hex_secret

# Optional dedicated key for encrypting MT5 credentials stored in SQLite.
# Generate one with: openssl rand -hex 32
CONFIG_ENCRYPTION_KEY=your_config_encryption_key

# Admin Credentials (Required for login)
ADMIN_USER=admin
ADMIN_PASS=your_strong_password_here

# Restricted CORS Origins (Comma-separated)
# Only these domains will be allowed to access the API
ALLOWED_ORIGINS=http://localhost:5000,http://127.0.0.1:5000

# --- STRIPE WEBHOOKS ---
# STRIPE_WEBHOOK_SECRET is highly recommended for production to prevent spoofing.
STRIPE_API_KEY=sk_test_or_live_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
ALLOW_UNSIGNED_STRIPE_WEBHOOK=false

# --- LIVE VPS DEPLOYMENT: NATIVE MT5 AUTO-TRADING ---
# Requires a local MT5 terminal and the MetaTrader5 Python package on Windows VPS.
MT5_LOGIN=your_mt5_account_number
MT5_PASSWORD=your_mt5_password
MT5_SERVER=your_broker_server_name

# Trading Control (To trade live money, set paper to false and approved to true)
MT5_AUTO_TRADE=true
MT5_PAPER_MODE=false
LIVE_TRADING_APPROVED=true
REQUIRE_BROKER_DATA_FOR_LIVE=true
DATA_PROVIDER=mt5
MAX_PRETRADE_SPREAD_PIPS=3.0

# Cent Account Suffix (Important for brokers like HFM)
# e.g., if HFM symbols are EURUSDc, set this to "c". Leave empty for standard accounts.
MT5_SYMBOL_SUFFIX=c
