[Unit]
Description=TradingExpert Signal Tracker Service
After=network.target

[Service]
Type=simple
WorkingDirectory=/home/evans/mumo-syntax-capital
Environment="PYTHONPATH=/home/evans/mumo-syntax-capital"
ExecStart=/home/evans/mumo-syntax-capital/venv/bin/python /home/evans/mumo-syntax-capital/signal_tracker.py
Restart=always
RestartSec=30

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=mumo-tracker

[Install]
WantedBy=multi-user.target
